cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnp
.pnp.js

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Build output
dist/
build/
out/
*.tsbuildinfo

# Coverage / test output
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.eslintcache
.npm/

# IDE / editor
.vscode/
.idea/
.zed/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Optional npm cache directory
.npm

# Lock files - keep package-lock.json, ignore others if mixing tools
yarn.lock
pnpm-lock.yaml
EOF
